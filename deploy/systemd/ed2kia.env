# ed2kIA - Archivo de configuración de entorno
# Copiar a /etc/ed2kia/ed2kia.env y ajustar valores

# ============================================
# Configuración del nodo
# ============================================
# ID único del nodo (dejar vacío para generar automáticamente)
ED2KIA_NODE_ID=

# Puerto base para P2P (TCP/UDP)
ED2KIA_PORT=9000

# Dirección de bind (0.0.0.0 para todos los interfaces)
ED2KIA_BIND_ADDRESS=0.0.0.0

# ============================================
# Configuración P2P
# ============================================
# Bootnodes para descubrimiento (separados por coma)
ED2KIA_BOOTNODES=/ip4/127.0.0.1/tcp/9000/p2p/12D3Koo...

# Topic principal de GossipSub
ED2KIA_GOSSIPSUB_TOPIC=ed2k-mainnet

# Intervalo de heartbeat en milisegundos
ED2KIA_HEARTBEAT_INTERVAL=5000

# ============================================
# Configuración SAE (Sparse Autoencoder)
# ============================================
# Ruta al directorio de modelos SAE
ED2KIA_SAE_MODELS_DIR=/opt/ed2kia/models

# Modelo SAE por defecto
ED2KIA_DEFAULT_SAE_MODEL=sae_4x1024x4096.onnx

# Ruta para módulos WASM
ED2KIA_WASM_MODULES_DIR=/opt/ed2kia/wasm_modules

# ============================================
# Configuración de consenso
# ============================================
# Mínimo de votos para consenso
ED2KIA_CONSENSUS_MIN_VOTES=3

# Umbral de acuerdo (0.0 - 1.0)
ED2KIA_CONSENSUS_AGREEMENT_THRESHOLD=0.67

# Ventana de tiempo para batches en ms
ED2KIA_CONSENSUS_TIME_WINDOW=30000

# ============================================
# Configuración ZKP
# ============================================
# Habilitar verificación ZKP
ED2KIA_ZKP_ENABLED=true

# Curva elíptica para ZKP (bn254 por defecto)
ED2KIA_ZKP_CURVE=bn254

# ============================================
# Configuración de red
# ============================================
# Modo de red (mainnet/testnet/devnet)
ED2KIA_NETWORK=testnet

# ============================================
# Logging
# ============================================
# Nivel de log (trace, debug, info, warn, error)
RUST_LOG=info

# ============================================
# Seguridad
# ============================================
# Límite de memoria para sandbox WASM en MB
ED2KIA_WASM_MEMORY_LIMIT=256

# Habilitar sandbox WASM
ED2KIA_WASM_SANDBOX_ENABLED=true
